# ──────────────────────────────────────────────────────
# Frontend Environment — React Native (Expo)
# Copy this file to .env and fill in your values.
# ──────────────────────────────────────────────────────

# Base URL of the Laravel backend API.
# Use your machine's local IP when testing on a physical device
# (e.g. http://192.168.1.x:8000/api).
# For an emulator you can use http://10.0.2.2:8000/api (Android)
# or http://localhost:8000/api (iOS simulator).
EXPO_PUBLIC_API_BASE_URL=http://192.168.1.x:8000/api
