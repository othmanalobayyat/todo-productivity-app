# ──────────────────────────────────────────────────────────────
# Frontend Environment — React Native (Expo)
# Copy this file to .env and fill in your values.
# ──────────────────────────────────────────────────────────────

# Full URL of the active backend API.
#
# Primary backend (Node.js / Express — port 3000):
#   Use your machine's local IP when testing on a physical device.
#   EXPO_PUBLIC_API_BASE_URL=http://192.168.1.x:3000/api
#
#   For Android emulator:
#   EXPO_PUBLIC_API_BASE_URL=http://10.0.2.2:3000/api
#
#   For iOS simulator:
#   EXPO_PUBLIC_API_BASE_URL=http://localhost:3000/api
#
# Alternative backend (Laravel — port 8000): replace 3000 with 8000 above.
#
# Production (Render-hosted Node backend):
#   EXPO_PUBLIC_API_BASE_URL=https://your-backend.onrender.com/api

EXPO_PUBLIC_API_BASE_URL=http://192.168.1.x:3000/api
