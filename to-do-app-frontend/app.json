{
  "expo": {
    "name": "Todo Productivity App",
    "slug": "todo-productivity-app",
    "scheme": "todoapp",
    "version": "1.0.2",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/logoWhite.png",
      "resizeMode": "contain",
      "backgroundColor": "#451E5D"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.othmanlearn.todoproductivity",
      "versionCode": 3,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "name": "Orvia",
      "shortName": "Orvia",
      "description": "Your calm, minimal productivity companion.",
      "lang": "en",
      "themeColor": "#451E5D",
      "backgroundColor": "#451E5D"
    },
    "plugins": ["@react-native-community/datetimepicker", "expo-font"],
    "extra": {
      "eas": {
        "projectId": "11f49933-0065-419e-9603-cb7e14662eed"
      }
    },
    "owner": "othmanlearn"
  }
}
