# ──────────────────────────────────────────────────────────────
# Node.js Backend Environment — Express + Prisma + Resend
# Copy this file to .env and fill in your values.
# ──────────────────────────────────────────────────────────────

# ── Database (Supabase PostgreSQL) ─────────────────────────────────────────
# Connection pooler URL — used by the running app for all queries.
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-1-ap-northeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection URL — used only by `prisma db push` and `prisma migrate dev`.
# Both DATABASE_URL and DIRECT_URL must be set, or migrations will fail.
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-1-ap-northeast-1.pooler.supabase.com:5432/postgres"

# ── Authentication ──────────────────────────────────────────────────────────
# Secret used to sign and verify JWT tokens. Use a long random string in production.
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret_here

# ── Server ──────────────────────────────────────────────────────────────────
# Port the Express server listens on. Defaults to 3000 if not set.
PORT=3000

# Optional: restrict CORS to specific origins (comma-separated).
# Leave unset to allow all origins (fine for local dev / demo).
# Example: CORS_ORIGIN=https://your-app.vercel.app
# CORS_ORIGIN=

# ── Password Reset ──────────────────────────────────────────────────────────
# Base URL used to build the password reset link in emails.
# Use your custom scheme for mobile: todoapp://
# Use your web domain for Vercel deployment: https://your-app.vercel.app
APP_URL=todoapp://

# Resend API key — get one at https://resend.com (free tier: 3,000 emails/month).
RESEND_API_KEY=re_your_api_key_here

# Sender email address. Must be from a verified domain in your Resend account.
EMAIL_FROM=noreply@mail.yourdomain.com
