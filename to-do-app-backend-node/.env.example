# ──────────────────────────────────────────────────────
# Node.js Backend Environment — Express + Prisma
# Copy this file to .env and fill in your values.
# ──────────────────────────────────────────────────────

# Supabase — connection pooler URL (used by the running app)
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-1-ap-northeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Supabase — direct connection URL (used by prisma db push / migrations only)
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-1-ap-northeast-1.pooler.supabase.com:5432/postgres"

# JWT secret used to sign and verify auth tokens.
# Use a long, random string in production.
JWT_SECRET=your_jwt_secret_here

# Server port (optional — defaults to 3000 if not set)
PORT=3000

# Optional: restrict CORS to specific origins (comma-separated).
# Leave unset to allow all origins (acceptable for demo).
# Example: CORS_ORIGIN=https://your-app.vercel.app
# CORS_ORIGIN=
